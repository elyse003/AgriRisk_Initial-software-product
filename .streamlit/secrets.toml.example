# Copy to .streamlit/secrets.toml and fill in. That file is gitignored:
# NEVER commit the client secret or the cookie secret.
#
# On Streamlit Cloud, paste the same contents into
#   Manage app -> Settings -> Secrets
# (Cloud has no filesystem secrets.toml.)
#
# ---------------------------------------------------------------------------
# Google sign-in ("Continue with Google")
# ---------------------------------------------------------------------------
# 1. https://console.cloud.google.com/ -> APIs & Services -> Credentials
# 2. Create OAuth client ID -> Web application
# 3. Authorised redirect URI must EXACTLY match redirect_uri below, including
#    the /oauth2callback path and the scheme. Add one entry per environment:
#       http://localhost:8501/oauth2callback
#       https://<your-app>.streamlit.app/oauth2callback
# 4. Configure the OAuth consent screen. While it is in "Testing", only the
#    Google accounts you add as test users can sign in.
#
# Until [auth] is set the "Continue with Google" button is hidden and the
# username/password form works exactly as before.

[auth]
# where Google sends the user back; must match the console entry exactly
redirect_uri = "http://localhost:8501/oauth2callback"
# signs the auth cookie. Generate with:  python -c "import secrets;print(secrets.token_hex(32))"
cookie_secret = "CHANGE_ME_random_64_hex_chars"

[auth.google]
client_id = "xxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ---------------------------------------------------------------------------
# Signs the session token carried in ?t= across full page reloads.
# Set this in production, or tokens are signed with a known dev default.
# ---------------------------------------------------------------------------
AGRIRISK_SECRET = "CHANGE_ME_random_64_hex_chars"