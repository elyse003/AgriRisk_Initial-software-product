# --- Data ---
# The cleaned processed data (small, real) and the trained models ARE committed,
# so the app clones-and-runs on real data with no rebuild step. Both regenerate
# via scripts/download_data.py -> prepare_data.py -> train_models.py.
# Large raw source downloads are NOT committed:
data/raw/wfp_food_prices_rwa.csv
data/raw/rwa-rainfall-subnat-full.csv
data/raw/CMO-Historical-Data-Monthly.xlsx
data/raw/worldbank_cpi_rwanda.csv

# runtime database (auto-created) and local exports
data/agririsk.db
*.db
data/feedback_export.csv

